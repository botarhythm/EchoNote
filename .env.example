# AI APIs
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Google Drive (setup-gcp.sh が自動設定)
GOOGLE_SERVICE_ACCOUNT_KEY=  # Base64エンコードしたサービスアカウントJSON
DRIVE_FOLDER_ID=             # EchoNoteフォルダのDrive ID
DRIVE_PROCESSED_FOLDER_ID=   # ProcessedフォルダのDrive ID（任意）

# Database
DATABASE_URL=postgresql://localhost:5432/echonote

# Polling
POLL_INTERVAL_MS=60000
NEXT_PUBLIC_POLL_INTERVAL_MS=10000

# ─── 自習室（digihara_jishushitsu）連携 ────────────────────────────
# 参加者URLのベース（クライアントにも露出するため NEXT_PUBLIC_ 接頭辞）
NEXT_PUBLIC_DIGIHARA_BASE_URL=https://digihara-jishushitsu.vercel.app
# 講師キー（秘密・サーバーサイドのみで使用）。digihara側の INSTRUCTOR_KEY_MOTOZAWA と一致させる
DIGIHARA_INSTRUCTOR_KEY=

# ─── EchoNote ingest API ───────────────────────────────────────────
# 外部アプリ（digihara等）が録音をPOSTする際の共有秘密鍵
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ECHONOTE_INGEST_TOKEN=

# ─── 自習室 招待モーダルの送信先（任意） ───────────────────────────
# Discord 用 Webhook URL（チャンネル設定 → 連携サービス → Webhook 作成）
DISCORD_WEBHOOK_URL=
# Slack 用 Incoming Webhook URL
SLACK_WEBHOOK_URL=

# ─── ブランドモード（任意 / 深層分析モードの opt-in 化） ───────────────
# デフォルトでは EchoNote は汎用議事録モードのみが動作します。
# 自分のブランド・コーチング様式に合わせた深層分析モードを有効化したい場合だけ
# 以下を埋めてください。
#
# 有効化フラグ（true で「ブランドモード」のセグメントが UI に表示される）
NEXT_PUBLIC_BRAND_MODE_ENABLED=false
# UI 上のモードラベル（例: "Botarhythmセッション" / "塚越メンタリング" など）
NEXT_PUBLIC_BRAND_LABEL=
# サーバー側のブランド情報（システムプロンプトに埋め込まれる）
BRAND_NAME=
BRAND_SHORT_NAME=
BRAND_HOST_NAME=
BRAND_HOST_FULL_NAME=
BRAND_HOST_KEYWORDS=
BRAND_PHILOSOPHY=
BRAND_APPROACH=
BRAND_HOST_STRENGTH=
BRAND_SESSION_FLOW=
